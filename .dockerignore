__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Virtual environments
venv/
.venv/

# Runtime-generated data (not baked into image)
data/chroma/
data/personas/

# Development / documentation
docs/
tests/
old_reference/
.agent/
.vscode/
.qodo/

# Database files
*.sqlite3

# OS files
.DS_Store
Thumbs.db
